    1: _MOCK_CLAIM_DATA = {"letter": "# Letter", "commitment_hash": "abc123"}
       
       # ---------------------------------------------------------------------------
       # Module-level import — load iris-local.py by path (it's not a package)
       # ---------------------------------------------------------------------------
    1: _MODULE_PATH = os.path.join(os.path.dirname(__file__), "..", "iris-local.py")
    1: _spec = importlib.util.spec_from_file_location("iris_local", _MODULE_PATH)
    1: _mod = importlib.util.module_from_spec(_spec)
    1: _spec.loader.exec_module(_mod)
       
    1: load_config = _mod.load_config
    1: load_system_prompt = _mod.load_system_prompt
    1: load_model = _mod.load_model
    1: parse_args = _mod.parse_args
    1: create_app = _mod.create_app
    1: main = _mod.main
    1: _ROOT = _mod._ROOT
    1: _CONFIG_PATH = _mod._CONFIG_PATH
    1: _SYSTEM_PROMPT_PATH = _mod._SYSTEM_PROMPT_PATH
       
       
