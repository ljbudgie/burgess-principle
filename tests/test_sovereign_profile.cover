    1: def test_decrypt_profile_payload_returns_original_json(tmp_path):
    2:     result = setup_personal_profile(
    1:         vault_passphrase="correct horse battery staple",
    1:         root=tmp_path,
    1:         name="Lewis",
           )
    1:     raw_record = json.loads(Path(result["stored_path"]).read_text(encoding="utf-8"))
       
    2:     payload = decrypt_profile_payload(
    1:         raw_record["encrypted_payload"],
    1:         "correct horse battery staple",
           )
       
    1:     assert payload["name"] == "Lewis"
    1:     assert verify_personal_profile(payload) is True
       
       
    1: def test_load_personal_profile_summary_returns_none_when_name_missing(tmp_path):
    1:     path = profile_path(tmp_path)
    1:     path.parent.mkdir(parents=True, exist_ok=True)
    2:     path.write_text(
    2:         json.dumps(
    1:             {
    1:                 "version": "1.1.1",
    1:                 "record_type": "personal-sovereign-profile",
    1:                 "stored_at": "2026-04-11T00:00:00+00:00",
                   }
               ),
    1:         encoding="utf-8",
           )
       
    1:     assert load_personal_profile_summary(root=tmp_path) is None
