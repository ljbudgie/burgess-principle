    2: class TestVerifyInstrumentValidation:
    1:     def test_none_reasoning_text_raises_type_error(self):
    2:         with pytest.raises(TypeError, match="reasoning_text must be a string"):
    1:             verify_instrument(None, SAMPLE_HASH)  # type: ignore[arg-type]
       
    1:     def test_int_reasoning_text_raises_type_error(self):
    2:         with pytest.raises(TypeError, match="reasoning_text must be a string"):
    1:             verify_instrument(123, SAMPLE_HASH)  # type: ignore[arg-type]
       
    1:     def test_none_provided_hash_raises_type_error(self):
    2:         with pytest.raises(TypeError, match="provided_hash must be a string"):
    1:             verify_instrument(SAMPLE_TEXT, None)  # type: ignore[arg-type]
       
    1:     def test_empty_reasoning_text_raises_value_error(self):
    2:         with pytest.raises(ValueError, match="must not be empty"):
    1:             verify_instrument("", SAMPLE_HASH)
       
    1:     def test_short_hash_raises_value_error(self):
    2:         with pytest.raises(ValueError, match="64-character hexadecimal"):
    1:             verify_instrument(SAMPLE_TEXT, "abc123")
       
    1:     def test_non_hex_hash_raises_value_error(self):
    2:         with pytest.raises(ValueError, match="64-character hexadecimal"):
    1:             verify_instrument(SAMPLE_TEXT, "g" * 64)
       
    1:     def test_int_provided_hash_raises_type_error(self):
    2:         with pytest.raises(TypeError, match="provided_hash must be a string"):
    1:             verify_instrument(SAMPLE_TEXT, 12345)  # type: ignore[arg-type]
       
    1:     def test_list_reasoning_text_raises_type_error(self):
    2:         with pytest.raises(TypeError, match="reasoning_text must be a string"):
    1:             verify_instrument(["text"], SAMPLE_HASH)  # type: ignore[arg-type]
       
    1:     def test_hash_too_long_raises_value_error(self):
    2:         with pytest.raises(ValueError, match="64-character hexadecimal"):
    1:             verify_instrument(SAMPLE_TEXT, "a" * 65)
       
    1:     def test_hash_63_chars_raises_value_error(self):
    2:         with pytest.raises(ValueError, match="64-character hexadecimal"):
    1:             verify_instrument(SAMPLE_TEXT, "a" * 63)
       
    1:     def test_hash_with_spaces_raises_value_error(self):
    2:         with pytest.raises(ValueError, match="64-character hexadecimal"):
    1:             verify_instrument(SAMPLE_TEXT, "a" * 32 + " " * 32)
       
    1:     def test_hash_with_0x_prefix_raises_value_error(self):
    2:         with pytest.raises(ValueError, match="64-character hexadecimal"):
    1:             verify_instrument(SAMPLE_TEXT, "0x" + "a" * 62)
       
    1:     def test_bool_provided_hash_raises_type_error(self):
    2:         with pytest.raises(TypeError, match="provided_hash must be a string"):
    1:             verify_instrument(SAMPLE_TEXT, True)  # type: ignore[arg-type]
       
       
