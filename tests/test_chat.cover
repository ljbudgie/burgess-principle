    1:         mock_module = MagicMock(OpenAI=mock_openai_cls)
    2:         with patch.dict(os.environ, {"IRIS_API_KEY": "test-key", "IRIS_BASE_URL": "https://custom.api/v1"}):
    2:             with patch.dict("sys.modules", {"openai": mock_module}):
    1:                 _get_client()
    2:         mock_openai_cls.assert_called_once_with(
    1:             api_key="test-key",
    1:             base_url="https://custom.api/v1",
               )
       
    1:     def test_defaults_base_url(self):
