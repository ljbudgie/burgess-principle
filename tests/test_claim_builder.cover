    1:     def test_crypto_exchange_flow_generates_signed_vault_record(self, tmp_path):
    1:         profile = _build_profile(tmp_path)
       
    2:         with patch.object(claim_builder, "_ROOT", tmp_path):
    2:             result = auto_generate_claim(
    1:                 "A crypto exchange froze my account and blocked withdrawals.",
    1:                 profile,
                   )
       
    3:         assert result["scenario"]["template"] == (
    2:             "CRYPTO_EXCHANGE_ACCOUNT_RESTRICTION_WITH_BURGESS.md"
               )
    1:         assert "Alex Example" in result["letter"]
    1:         assert "Example Exchange" in result["letter"]
    1:         assert "0xabc123" in result["letter"]
    1:         assert result["commitment_hash"] in result["onchain_notice"]
    1:         assert result["unresolved_placeholders"] == []
    5:         assert [action["label"] for action in result["ui_actions"]] == [
                   "Save",
                   "Generate Commitment",
                   "Copy Letter",
                   "On-Chain Notice",
               ]
       
    2:         verification = verify_onchain_receipt(
    1:             result["commitment_hash"],
    1:             result["signature"],
    1:             result["public_key"],
               )
    1:         assert verification.valid is True
       
    1:         vault_path = Path(result["vault_record"]["path"])
    1:         assert vault_path.exists()
    1:         raw_record = json.loads(vault_path.read_text(encoding="utf-8"))
    1:         assert raw_record["commitment_hash"] == result["commitment_hash"]
    1:         assert result["letter"] not in raw_record["encrypted_payload"]
       
    2:         decrypted_payload = claim_builder._decrypt_vault_payload(
    1:             raw_record["encrypted_payload"],
    1:             profile["vault_passphrase"],
               )
    1:         payload = json.loads(decrypted_payload)
    1:         assert payload["letter"] == result["letter"]
    1:         assert payload["onchain_claim"]["public_key"] == result["public_key"]
       
