    1:     def test_messages_filtering(self):
               """Only user and assistant messages with content are forwarded."""
    3:         body = json.dumps({
    2:             "messages": [
    1:                 {"role": "user", "content": "Hello"},
    1:                 {"role": "system", "content": "ignored"},
    1:                 {"role": "assistant", "content": "Hi there"},
    1:                 {"role": "user", "content": ""},
    1:                 {"role": "tool", "content": "ignored"},
                   ]
    1:         }).encode()
    1:         h = _make_handler(body)
    1:         h.headers = {"Content-Length": str(len(body))}
       
    1:         mock_client = MagicMock()
    1:         mock_client.chat.completions.create.return_value = []
       
    2:         with patch.dict(os.environ, {"IRIS_API_KEY": "test-key"}):
    2:             with patch.object(_chat_mod, "_get_client", return_value=mock_client):
    1:                 h.do_POST()
       
    1:         call_kwargs = mock_client.chat.completions.create.call_args
    1:         api_messages = call_kwargs.kwargs.get("messages") or call_kwargs[1].get("messages")
    1:         assert api_messages[0]["role"] == "system"
    4:         user_assistant_msgs = [m for m in api_messages if m["role"] != "system"]
    1:         assert len(user_assistant_msgs) == 2
    1:         assert user_assistant_msgs[0] == {"role": "user", "content": "Hello"}
    1:         assert user_assistant_msgs[1] == {"role": "assistant", "content": "Hi there"}
       
