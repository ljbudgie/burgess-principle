    1:     details: str
       
       
       # ---------------------------------------------------------------------------
       # Endpoints
       # ---------------------------------------------------------------------------
       
    2: @app.post("/verify", response_model=VerifyResponse)
    2: def verify(payload: VerifyRequest) -> VerifyResponse:
           """Run the Burgess Principle Binary Test and return a structured result."""
    8:     result = verify_instrument(payload.reasoning_text, payload.provided_hash)
    8:     data = result.to_dict()
    8:     return VerifyResponse(**data)
       
       
    2: @app.post("/claims/verify", response_model=ClaimVerifyResponse)
    2: def verify_claim(payload: ClaimVerifyRequest) -> ClaimVerifyResponse:
           """Verify an on-chain Burgess Claim receipt (Ed25519 signature check).
       
           This endpoint checks that the Ed25519 signature over the commitment
           hash is valid for the given public key.  It does **not** interact with
           any blockchain — it performs the same cryptographic verification that
           would be done off-chain after reading the claim from a contract.
           """
           # Lazy import to keep PyNaCl optional.
    3:     sdk_path = os.path.join(os.path.dirname(__file__), "onchain-protocol", "sdk")
    3:     if sdk_path not in sys.path:
    1:         sys.path.insert(0, sdk_path)
       
    3:     from onchain_claims import verify_onchain_receipt
       
    6:     result = verify_onchain_receipt(
    3:         commitment_hash=payload.commitment_hash,
    3:         signature=payload.signature,
    3:         public_key_hex=payload.public_key_hex,
           )
    6:     return ClaimVerifyResponse(
    3:         valid=result.valid,
    3:         commitment_hash=result.commitment_hash,
    3:         public_key=result.public_key,
    3:         details=result.details,
           )
