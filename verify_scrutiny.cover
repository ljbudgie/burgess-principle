   37:     calculated_hash = hashlib.sha256(reasoning_text.encode()).hexdigest()
       
           # Constant-time comparison to prevent timing side-channel attacks.
   37:     if hmac.compare_digest(calculated_hash, provided_hash.lower()):
   25:         return SOVEREIGN
   12:     return NULL
       
       
       # ---------------------------------------------------------------------------
       # CLI entry point
       # ---------------------------------------------------------------------------
       
    2: def main(argv: list[str] | None = None) -> int:
           """Command-line interface for the Burgess Principle Binary Test."""
   36:     parser = argparse.ArgumentParser(
   18:         description="The Burgess Principle Binary Test — SOVEREIGN / NULL verification.",
