    2: class TestLoadConfig:
    1:     def test_defaults_without_config_file(self, tmp_path):
               """When iris-config.json doesn't exist, defaults are used."""
    2:         with patch.object(_mod, "_CONFIG_PATH", tmp_path / "nonexistent.json"):
    1:             cfg = load_config()
    1:         assert cfg["model_path"] == "models/model.gguf"
    1:         assert cfg["context_size"] == 2048
    1:         assert cfg["port"] == 8000
    1:         assert cfg["gpu_acceleration"] is False
       
    1:     def test_reads_config_file(self, tmp_path):
               """Values from iris-config.json override defaults."""
    1:         config_file = tmp_path / "iris-config.json"
    2:         config_file.write_text(json.dumps({
    1:             "model_path": "custom/model.gguf",
    1:             "port": 9090,
               }))
    2:         with patch.object(_mod, "_CONFIG_PATH", config_file):
    1:             cfg = load_config()
    1:         assert cfg["model_path"] == "custom/model.gguf"
    1:         assert cfg["port"] == 9090
               # Defaults preserved for unset values
    1:         assert cfg["context_size"] == 2048
    1:         assert cfg["gpu_acceleration"] is False
       
    1:     def test_cli_overrides_config_file(self, tmp_path):
               """CLI arguments take priority over config file."""
    1:         config_file = tmp_path / "iris-config.json"
    1:         config_file.write_text(json.dumps({"port": 9090}))
    2:         args = argparse.Namespace(
    1:             model="cli-model.gguf",
    1:             context=4096,
    1:             port=7777,
    1:             gpu=True,
               )
    2:         with patch.object(_mod, "_CONFIG_PATH", config_file):
    1:             cfg = load_config(args)
    1:         assert cfg["model_path"] == "cli-model.gguf"
    1:         assert cfg["context_size"] == 4096
    1:         assert cfg["port"] == 7777
    1:         assert cfg["gpu_acceleration"] is True
       
    1:     def test_invalid_json_uses_defaults(self, tmp_path):
               """Malformed config file falls back to defaults."""
    1:         config_file = tmp_path / "iris-config.json"
    1:         config_file.write_text("not valid json {{{")
    2:         with patch.object(_mod, "_CONFIG_PATH", config_file):
    1:             cfg = load_config()
    1:         assert cfg["port"] == 8000
       
    1:     def test_cli_none_values_do_not_override(self, tmp_path):
               """CLI args set to None don't override config file values."""
    1:         config_file = tmp_path / "iris-config.json"
    1:         config_file.write_text(json.dumps({"port": 5555}))
    1:         args = argparse.Namespace(model=None, context=None, port=None, gpu=False)
    2:         with patch.object(_mod, "_CONFIG_PATH", config_file):
    1:             cfg = load_config(args)
    1:         assert cfg["port"] == 5555
       
       
