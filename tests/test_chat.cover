    2: class TestLogMessage:
    1:     def test_log_message_does_nothing(self, capsys):
    1:         h = _make_handler(b"")
    1:         h.log_message("test %s", "value")
    1:         captured = capsys.readouterr()
    1:         assert captured.out == ""
    1:         assert captured.err == ""
       
       
