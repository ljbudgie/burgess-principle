    1: def test_public_helpers_generate_and_encrypt_claim(tmp_path):
    1:     profile = _build_profile(tmp_path)
    2:     template = claim_builder.load_template(
    1:         "CRYPTO_EXCHANGE_ACCOUNT_RESTRICTION_WITH_BURGESS.md"
           )
    2:     filled = claim_builder.fill_placeholders(
    1:         template,
    1:         profile,
    1:         {
    1:             "date": "2026-04-11",
    1:             "team_name": profile["team_name"],
    1:             "target_entity": profile["institution_name"],
    1:             "reference": profile["reference"],
    1:             "query_summary": "The exchange froze my account.",
    1:             "transaction_hashes": profile["transaction_hash"],
    1:             "wallet_addresses": profile["wallet_address"],
    1:             "full_name": profile["full_name"],
    1:             "contact_details": f'{profile["email"]} | {profile["phone"]}',
               },
           )
       
    2:     claim = claim_builder.generate_commitment(
    1:         filled,
    1:         profile,
    1:         category="exchange",
    1:         target_entity=profile["institution_name"],
           )
    7:     assert verify_onchain_receipt(
    4:         claim["commitment_hash"], claim["signature"], claim["public_key"]
    3:     ).valid is True
       
    2:     with patch.object(claim_builder, "_ROOT", tmp_path):
    2:         vault = claim_builder.encrypt_to_vault(
    1:             {"created_at": claim["timestamp"], "letter": filled, "onchain_claim": claim},
    1:             profile,
    1:             "CRYPTO_EXCHANGE_ACCOUNT_RESTRICTION_WITH_BURGESS.md",
               )
    1:     raw_record = json.loads(Path(vault["path"]).read_text(encoding="utf-8"))
    2:     payload = json.loads(
    2:         claim_builder._decrypt_vault_payload(
    1:             raw_record["encrypted_payload"], profile["vault_passphrase"]
               )
           )
    1:     assert payload["letter"] == filled
       
       
    1: def test_fill_placeholders_supports_banking_template_labels():
    1:     profile = {
    1:         "full_name": "Alex Example",
    1:         "bank_building_society_name": "Example Bank",
    1:         "account_number_sort_code_if_relevant": "12-34-56 / 12345678",
    1:         "contact_email": "alex@example.com",
           }
    1:     template = claim_builder.load_template("DIRECT_DEBIT_REFUND_WITH_BURGESS.md")
    2:     filled = claim_builder.fill_placeholders(
    1:         template,
    1:         profile,
    1:         {
    1:             "date": "2026-04-11",
    1:             "amount": "150.00",
    1:             "company_organisation_name_or_reference": "Example Utilities Ltd",
    2:             claim_builder._norm(
    1:                 "refused the refund / investigated itself and rejected my claim / reversed the refund / pushed me to the Financial Ombudsman"
    1:             ): "refused the refund",
               },
           )
       
    1:     assert "Dear Example Bank Complaints / Fraud / Customer Services Team," in filled
    1:     assert "On 2026-04-11, a Direct Debit of £150.00 was taken" in filled
    1:     assert "by Example Utilities Ltd." in filled
    1:     assert "The bank has refused the refund." in filled
    1:     assert "Alex Example" in filled
    1:     assert "12-34-56 / 12345678" in filled
    1:     assert "alex@example.com" in filled
    1:     _assert_all_placeholders_resolved(filled)
       
       
    1: def test_fill_placeholders_supports_crypto_exchange_template_context(tmp_path):
