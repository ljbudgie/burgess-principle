    1:         "axiom": "A corrupted source (0) can only produce corrupted outputs.",
           },
       ]
       
       
    1: def get_defect(defect_id: str) -> Defect | None:
           """Return the defect definition matching *defect_id*, or ``None``."""
  113:     for defect in DEFECT_SCHEMA:
   99:         if defect["id"] == defect_id:
   19:             return defect
   14:     return None
       
       
    1: def list_defects() -> list[str]:
           """Return a list of all known defect IDs."""
   40:     return [d["id"] for d in DEFECT_SCHEMA]
