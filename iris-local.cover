    1: def parse_args(argv: list[str] | None = None) -> argparse.Namespace:
           """Parse command-line arguments."""
    2:     parser = argparse.ArgumentParser(
    1:         description="Iris Local — sovereign AI inference for the Burgess Principle",
           )
    2:     parser.add_argument(
    1:         "--model",
    1:         type=str,
    1:         default=None,
    1:         help="Path to a GGUF model file (overrides iris-config.json)",
           )
    2:     parser.add_argument(
    1:         "--context",
    1:         type=int,
    1:         default=None,
    1:         help="Context window size in tokens (default: 2048)",
           )
    2:     parser.add_argument(
    1:         "--port",
    1:         type=int,
    1:         default=None,
    1:         help="Port for the local server (default: 8000)",
           )
    2:     parser.add_argument(
    1:         "--gpu",
    1:         action="store_true",
    1:         default=False,
    1:         help="Enable GPU acceleration (requires compatible llama-cpp-python build)",
           )
    2:     parser.add_argument(
    1:         "--no-browser",
    1:         action="store_true",
    1:         default=False,
    1:         help="Don't open the browser automatically",
           )
    1:     return parser.parse_args(argv)
       
       
    1: def main(argv: list[str] | None = None) -> None:
           """Load config, load model, start server."""
    1:     args = parse_args(argv)
    1:     cfg = load_config(args)
       
           # Load system prompt
    1:     if not _SYSTEM_PROMPT_PATH.exists():
               log.error("System prompt not found: %s", _SYSTEM_PROMPT_PATH)
               sys.exit(1)
       
    1:     system_prompt = load_system_prompt()
    1:     log.info("System prompt loaded (%d chars).", len(system_prompt))
       
           # Load model
    1:     load_model(cfg)
       
           # Create app
    1:     personal_profile = load_personal_profile_summary()
    1:     if personal_profile:
               log.info(
                   "Loaded sovereign profile for %s (%s).",
                   personal_profile["name"],
                   personal_profile["key_fingerprint"],
               )
           else:
    1:         log.info("No sovereign personal profile found yet. Use Setup My Identity to create one.")
       
    1:     app = create_app(system_prompt, personal_profile=personal_profile, runtime_config=cfg)
       
    1:     port = cfg["port"]
       
           # Open browser after a short delay
    1:     if not args.no_browser:
       
               def _open_browser():
                   webbrowser.open(f"http://localhost:{port}")
       
               threading.Timer(1.5, _open_browser).start()
       
    1:     log.info("Starting Iris Local on http://localhost:%d", port)
    1:     log.info("Press Ctrl+C to stop.")
       
    1:     uvicorn.run(app, host="127.0.0.1", port=port, log_level="warning")
       
       
    1: if __name__ == "__main__":
    1:     main()
