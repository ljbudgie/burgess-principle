               64-character hexadecimal string.
           """
           # --- Input validation ------------------------------------------------
           # Reject non-string types early to provide clear error messages.
   61:     if not isinstance(reasoning_text, str):
   10:         raise TypeError(
    5:             f"reasoning_text must be a string, got {type(reasoning_text).__name__}"
               )
   56:     if not isinstance(provided_hash, str):
   10:         raise TypeError(
    5:             f"provided_hash must be a string, got {type(provided_hash).__name__}"
               )
   51:     if not reasoning_text:
    4:         raise ValueError("reasoning_text must not be empty")
           # SHA-256 digests are exactly 64 hex characters.
 2593:     if len(provided_hash) != 64 or not all(
 2509:         c in "0123456789abcdefABCDEF" for c in provided_hash
           ):
   20:         raise ValueError(
   10:             "provided_hash must be a 64-character hexadecimal string"
               )
       
           # Compute SHA-256 of the reasoning text for comparison against the
