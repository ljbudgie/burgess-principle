                   return real_import(name, *args, **kwargs)
       
  755:         saved = {k: sys.modules.pop(k) for k in list(sys.modules) if k == "nacl" or k.startswith("nacl.")}
    1:         try:
    2:             with pytest.raises(ImportError, match="PyNaCl"):
    1:                 builtins.__import__ = block_nacl
    2:                 verify_onchain_receipt(
    1:                     commitment_hash="aa" * 32,
    1:                     signature="bb" * 64,
    1:                     public_key_hex="cc" * 32,
                       )
               finally:
    1:             builtins.__import__ = real_import
    1:             sys.modules.update(saved)
