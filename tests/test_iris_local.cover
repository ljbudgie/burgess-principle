    2: class TestLoadSystemPrompt:
    1:     def test_returns_string(self):
    1:         prompt = load_system_prompt()
    1:         assert isinstance(prompt, str)
       
    1:     def test_prompt_is_non_empty(self):
    1:         prompt = load_system_prompt()
    1:         assert len(prompt.strip()) > 0
       
    1:     def test_prompt_mentions_iris(self):
    1:         prompt = load_system_prompt()
    1:         assert "Iris" in prompt
       
    1:     def test_prompt_mentions_burgess_principle(self):
    1:         prompt = load_system_prompt()
    1:         assert "Burgess Principle" in prompt
       
       
