    1: def _assert_all_placeholders_resolved(text: str) -> None:
    3:     assert claim_builder._PLACEHOLDER_RE.findall(text) == []
       
       
    1: def test_classify_scenario_reads_fast_match_table():
    2:     scenario = claim_builder.classify_scenario(
    1:         "I want to reference a hash, signature, receipt, or on-chain claim."
           )
       
    1:     assert scenario["template"] == "CRYPTOGRAPHIC_PROOF_AND_ONCHAIN_NOTICE_WITH_BURGESS.md"
    3:     assert scenario["situation"] == (
    2:         "I want to reference a hash, signature, receipt, or on-chain claim"
           )
    1:     assert scenario["score"] > 0
       
       
