    1:         assert "Individual Scrutiny Verified." in captured.out
       
    1:     def test_null_output_includes_description(self, capsys):
    1:         main([SAMPLE_TEXT, "a" * 64])
    1:         captured = capsys.readouterr()
    1:         assert "Information Mismatch / Bulk Noise." in captured.out
       
    1:     def test_sovereign_output_includes_value(self, capsys):
    1:         main([SAMPLE_TEXT, SAMPLE_HASH])
    1:         captured = capsys.readouterr()
    1:         assert "(1)" in captured.out
       
    1:     def test_null_output_includes_value(self, capsys):
