    2: class TestLoadSystemPrompt:
    1:     def test_returns_string(self):
    1:         prompt = _load_system_prompt()
    1:         assert isinstance(prompt, str)
       
    1:     def test_prompt_is_non_empty(self):
    1:         prompt = _load_system_prompt()
    1:         assert len(prompt.strip()) > 0
       
    1:     def test_prompt_mentions_iris(self):
    1:         prompt = _load_system_prompt()
    1:         assert "Iris" in prompt
       
    1:     def test_prompt_mentions_burgess_principle(self):
    1:         prompt = _load_system_prompt()
    1:         assert "Burgess Principle" in prompt
       
       
       # ---------------------------------------------------------------------------
       # Helpers
       # ---------------------------------------------------------------------------
       
    1: def _make_handler(request_data: bytes) -> handler:
           """Instantiate the handler with a fake request, suppressing __init__ side effects."""
   20:     h = handler.__new__(handler)
   20:     h.rfile = io.BytesIO(request_data)
   20:     h.wfile = io.BytesIO()
   20:     h.requestline = ""
   20:     h.command = ""
   20:     h.request_version = "HTTP/1.1"
   20:     h.close_connection = True
   20:     h.client_address = ("127.0.0.1", 12345)
       
           # Track response status and headers
   20:     h._response_code = None
   20:     h._response_headers = {}
       
   20:     def fake_send_response(code, message=None):
   19:         h._response_code = code
       
   20:     def fake_send_header(keyword, value):
   43:         h._response_headers[keyword] = value
       
   20:     def fake_end_headers():
   19:         pass
       
   20:     h.send_response = fake_send_response
   20:     h.send_header = fake_send_header
   20:     h.end_headers = fake_end_headers
       
   20:     return h
       
       
       # ---------------------------------------------------------------------------
       # handler.do_OPTIONS — CORS preflight
