    2: class TestPyNaClImportError:
    1:     """Verify friendly errors when PyNaCl is not installed."""
       
    1:     def test_generate_raises_import_error_without_nacl(self):
               """generate_onchain_claim raises ImportError when nacl is unavailable."""
    1:         import builtins
       
    1:         real_import = builtins.__import__
       
    1:         def block_nacl(name, *args, **kwargs):
    1:             if "nacl" in name:
    1:                 raise ImportError("Mocked: no nacl")
                   return real_import(name, *args, **kwargs)
       
               # Remove cached nacl modules so the lazy import fires again
  755:         saved = {k: sys.modules.pop(k) for k in list(sys.modules) if k == "nacl" or k.startswith("nacl.")}
    1:         try:
    2:             with pytest.raises(ImportError, match="PyNaCl"):
    1:                 builtins.__import__ = block_nacl
    2:                 generate_onchain_claim(
    1:                     claim_details="test",
    1:                     target_entity="entity",
    1:                     category="enforcement",
    1:                     private_key_hex="aa" * 32,
                       )
               finally:
    1:             builtins.__import__ = real_import
    1:             sys.modules.update(saved)
       
    1:     def test_verify_raises_import_error_without_nacl(self):
               """verify_onchain_receipt raises ImportError when nacl is unavailable."""
    1:         import builtins
       
    1:         real_import = builtins.__import__
       
    1:         def block_nacl(name, *args, **kwargs):
