       # _compute_commitment — deterministic
       # ---------------------------------------------------------------------------
       
    2: class TestComputeCommitment:
    1:     def test_deterministic(self):
    1:         h1 = _compute_commitment("a", "b", "cc" * 32, "dd" * 32)
    1:         h2 = _compute_commitment("a", "b", "cc" * 32, "dd" * 32)
    1:         assert h1 == h2
       
    1:     def test_different_inputs_different_hashes(self):
    1:         h1 = _compute_commitment("a", "b", "cc" * 32, "dd" * 32)
    1:         h2 = _compute_commitment("x", "b", "cc" * 32, "dd" * 32)
    1:         assert h1 != h2
       
    1:     def test_hash_is_64_hex_chars(self):
    1:         h = _compute_commitment("test", "ts", "aa" * 32, "bb" * 32)
    1:         assert len(h) == 64
    1:         int(h, 16)
       
       
       # ---------------------------------------------------------------------------
       # Full roundtrip: generate → verify signature → verify commitment
       # ---------------------------------------------------------------------------
       
    2: class TestFullRoundtrip:
    1:     def test_end_to_end(self):
               """Generate a claim, verify the signature, then verify the commitment."""
    2:         claim = generate_onchain_claim(
    1:             claim_details="My council tax was sent to enforcement without review",
    1:             target_entity="Example Council",
    1:             category="enforcement",
    1:             private_key_hex=PRIVATE_KEY,
    1:             timestamp=FIXED_TIMESTAMP,
    1:             nonce=FIXED_NONCE,
               )
       
               # Step 1: Verify the Ed25519 signature
    2:         sig_result = verify_onchain_receipt(
    1:             commitment_hash=claim.commitment_hash,
    1:             signature=claim.signature,
    1:             public_key_hex=claim.public_key,
               )
    1:         assert sig_result.valid
       
               # Step 2: Verify the commitment (selective disclosure)
    4:         assert verify_commitment(
    2:             claim_details="My council tax was sent to enforcement without review",
    1:             timestamp=FIXED_TIMESTAMP,
    1:             nonce=FIXED_NONCE,
    2:             public_key_hex=claim.public_key,
    2:             expected_hash=claim.commitment_hash,
               )
       
    1:     def test_roundtrip_with_auto_defaults(self):
               """Roundtrip with auto-generated timestamp and nonce."""
    2:         claim = generate_onchain_claim(
    1:             claim_details="Auto defaults test",
    1:             target_entity="Org",
    1:             category="oversight",
    1:             private_key_hex=PRIVATE_KEY,
               )
       
    2:         result = verify_onchain_receipt(
    1:             commitment_hash=claim.commitment_hash,
    1:             signature=claim.signature,
    1:             public_key_hex=claim.public_key,
               )
    1:         assert result.valid
       
    6:         assert verify_commitment(
    2:             claim_details="Auto defaults test",
    2:             timestamp=claim.timestamp,
    2:             nonce=claim.nonce,
    2:             public_key_hex=claim.public_key,
    2:             expected_hash=claim.commitment_hash,
               )
       
       
