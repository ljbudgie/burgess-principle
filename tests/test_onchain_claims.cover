    1: def _make_keypair():
           """Generate a fresh Ed25519 keypair using PyNaCl."""
    2:     from nacl.signing import SigningKey
       
    2:     sk = SigningKey.generate()
    2:     return sk.encode().hex(), sk.verify_key.encode().hex()
       
       
    1: PRIVATE_KEY, PUBLIC_KEY = _make_keypair()
    1: FIXED_NONCE = os.urandom(32).hex()
    1: FIXED_TIMESTAMP = "2026-04-10T12:00:00+00:00"
       
       
