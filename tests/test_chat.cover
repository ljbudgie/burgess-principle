       # ---------------------------------------------------------------------------
       # Module-level import helpers
       # ---------------------------------------------------------------------------
       
       # The api/ directory is not a Python package (no __init__.py) and there is
       # a top-level api.py that shadows the package namespace.  We load api/chat.py
       # directly using importlib so we can test it in isolation.
       
    2: _CHAT_MODULE_PATH = os.path.join(
    1:     os.path.dirname(__file__), "..", "api", "chat.py"
       )
    1: _spec = importlib.util.spec_from_file_location("api_chat", _CHAT_MODULE_PATH)
    1: _chat_mod = importlib.util.module_from_spec(_spec)
    1: _spec.loader.exec_module(_chat_mod)
       
    1: _load_system_prompt = _chat_mod._load_system_prompt
    1: _get_client = _chat_mod._get_client
    1: handler = _chat_mod.handler
       
       
       # ---------------------------------------------------------------------------
       # _load_system_prompt
