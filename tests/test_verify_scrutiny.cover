    1: """Tests for the Burgess Principle Binary Test (verify_scrutiny)."""
       
    1: import hashlib
    1: import runpy
    1: from pathlib import Path
       
    1: import pytest
       
    1: from verify_scrutiny import (
           NULL,
           SOVEREIGN,
           VerificationResult,
           main,
           verify_instrument,
       )
       
       
       # ---------------------------------------------------------------------------
       # Helpers
       # ---------------------------------------------------------------------------
       
    1: def _hash(text: str) -> str:
           """Return the SHA-256 hex-digest of *text*."""
   10:     return hashlib.sha256(text.encode()).hexdigest()
       
       
    1: SAMPLE_TEXT = "Was a human member of the team able to personally review the specific facts of my situation?"
    1: SAMPLE_HASH = _hash(SAMPLE_TEXT)
       
       
       # ---------------------------------------------------------------------------
       # VerificationResult
       # ---------------------------------------------------------------------------
       
    2: class TestVerificationResult:
    1:     def test_sovereign_is_truthy(self):
    1:         assert bool(SOVEREIGN) is True
       
    1:     def test_null_is_falsy(self):
    1:         assert bool(NULL) is False
       
    1:     def test_sovereign_value(self):
    1:         assert SOVEREIGN.value == 1
    1:         assert SOVEREIGN.label == "SOVEREIGN"
       
    1:     def test_null_value(self):
    1:         assert NULL.value == 0
    1:         assert NULL.label == "NULL"
       
    1:     def test_immutable(self):
    2:         with pytest.raises(AttributeError):
    1:             SOVEREIGN.value = 42  # type: ignore[misc]
       
    1:     def test_sovereign_description(self):
    1:         assert SOVEREIGN.description == "Individual Scrutiny Verified."
       
    1:     def test_null_description(self):
    1:         assert NULL.description == "Information Mismatch / Bulk Noise."
       
    1:     def test_null_immutable(self):
    2:         with pytest.raises(AttributeError):
    1:             NULL.label = "CHANGED"  # type: ignore[misc]
       
    1:     def test_sovereign_and_null_are_distinct(self):
    1:         assert SOVEREIGN is not NULL
    1:         assert SOVEREIGN != NULL
       
    1:     def test_custom_result_truthy_when_value_one(self):
    1:         custom = VerificationResult(value=1, label="X", description="Y")
    1:         assert bool(custom) is True
       
    1:     def test_custom_result_falsy_when_value_zero(self):
    1:         custom = VerificationResult(value=0, label="X", description="Y")
    1:         assert bool(custom) is False
       
    1:     def test_custom_result_falsy_when_value_non_one(self):
    1:         custom = VerificationResult(value=2, label="X", description="Y")
    1:         assert bool(custom) is False
       
    1:     def test_sovereign_to_dict(self):
    1:         d = SOVEREIGN.to_dict()
    1:         assert d == {"status": "SOVEREIGN", "code": 1, "description": "Individual Scrutiny Verified."}
       
    1:     def test_null_to_dict(self):
    1:         d = NULL.to_dict()
    1:         assert d == {"status": "NULL", "code": 0, "description": "Information Mismatch / Bulk Noise."}
       
    1:     def test_custom_to_dict(self):
    1:         custom = VerificationResult(value=1, label="X", description="Y")
    1:         assert custom.to_dict() == {"status": "X", "code": 1, "description": "Y"}
       
       
       # ---------------------------------------------------------------------------
       # verify_instrument — happy path
       # ---------------------------------------------------------------------------
       
    2: class TestVerifyInstrumentHappyPath:
    1:     def test_matching_hash_returns_sovereign(self):
    1:         result = verify_instrument(SAMPLE_TEXT, SAMPLE_HASH)
    1:         assert result is SOVEREIGN
    1:         assert result.value == 1
       
    1:     def test_mismatched_hash_returns_null(self):
    1:         wrong_hash = "a" * 64
    1:         result = verify_instrument(SAMPLE_TEXT, wrong_hash)
    1:         assert result is NULL
    1:         assert result.value == 0
       
    1:     def test_uppercase_hash_accepted(self):
    1:         result = verify_instrument(SAMPLE_TEXT, SAMPLE_HASH.upper())
    1:         assert result is SOVEREIGN
       
    1:     def test_mixed_case_hash_accepted(self):
   67:         mixed = "".join(
   65:             c.upper() if i % 2 else c for i, c in enumerate(SAMPLE_HASH)
               )
    1:         result = verify_instrument(SAMPLE_TEXT, mixed)
    1:         assert result is SOVEREIGN
       
    1:     def test_different_texts_produce_different_results(self):
    1:         text_a = "Hello"
    1:         text_b = "World"
    1:         assert verify_instrument(text_a, _hash(text_a)) is SOVEREIGN
    1:         assert verify_instrument(text_b, _hash(text_a)) is NULL
       
    1:     def test_unicode_text_verified(self):
    1:         text = "日本語テスト 🇬🇧"
    1:         assert verify_instrument(text, _hash(text)) is SOVEREIGN
       
    1:     def test_whitespace_only_text_is_accepted(self):
    1:         text = "   "
    1:         assert verify_instrument(text, _hash(text)) is SOVEREIGN
       
    1:     def test_multiline_text_verified(self):
    1:         text = "Line 1\nLine 2\nLine 3"
    1:         assert verify_instrument(text, _hash(text)) is SOVEREIGN
       
    1:     def test_very_long_text_verified(self):
    1:         text = "x" * 100_000
    1:         assert verify_instrument(text, _hash(text)) is SOVEREIGN
       
       
