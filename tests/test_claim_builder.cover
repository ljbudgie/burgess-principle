    1: def test_encrypt_to_vault_round_trips_payload_and_rejects_wrong_passphrase(tmp_path):
    1:     profile = _build_profile(tmp_path)
    1:     payload = {
    1:         "created_at": "2026-04-11T12:00:00+00:00",
    1:         "template": "CRYPTOGRAPHIC_PROOF_AND_ONCHAIN_NOTICE_WITH_BURGESS.md",
    1:         "letter": "proof letter",
    1:         "onchain_claim": {
    1:             "commitment_hash": "0xproof",
    1:             "public_key": "ab" * 32,
               },
           }
       
    2:     with patch.object(claim_builder, "_ROOT", tmp_path):
    2:         vault = claim_builder.encrypt_to_vault(
    1:             payload,
    1:             profile,
    1:             "CRYPTOGRAPHIC_PROOF_AND_ONCHAIN_NOTICE_WITH_BURGESS.md",
               )
       
    1:     raw_record = json.loads(Path(vault["path"]).read_text(encoding="utf-8"))
    1:     assert raw_record["template"] == payload["template"]
    1:     assert raw_record["created_at"] == payload["created_at"]
    1:     assert raw_record["commitment_hash"] == "0xproof"
    1:     assert raw_record["public_key"] == "ab" * 32
    1:     assert payload["letter"] not in raw_record["encrypted_payload"]
       
    2:     decrypted_payload = json.loads(
    2:         claim_builder._decrypt_vault_payload(
    1:             raw_record["encrypted_payload"], profile["vault_passphrase"]
               )
           )
    1:     assert decrypted_payload == payload
       
    2:     with pytest.raises(CryptoError):
    2:         claim_builder._decrypt_vault_payload(
    1:             raw_record["encrypted_payload"], "wrong passphrase"
               )
       
       
