    2: class TestDoPostErrors:
    1:     def test_missing_api_key_returns_503(self):
    1:         body = json.dumps({"messages": [{"role": "user", "content": "hello"}]}).encode()
    1:         h = _make_handler(body)
    1:         h.headers = {"Content-Length": str(len(body))}
    2:         with patch.dict(os.environ, {}, clear=True):
    1:             os.environ.pop("IRIS_API_KEY", None)
    1:             h.do_POST()
    1:         assert h._response_code == 503
    1:         data = json.loads(h.wfile.getvalue())
    1:         assert "error" in data
    1:         assert "IRIS_API_KEY" in data["error"]
       
