    2: class TestCLI:
    1:     def test_matching_hash_exits_zero(self):
    1:         assert main([SAMPLE_TEXT, SAMPLE_HASH]) == 0
       
    1:     def test_mismatched_hash_exits_one(self):
    1:         assert main([SAMPLE_TEXT, "a" * 64]) == 1
       
    1:     def test_invalid_input_exits_two(self):
    1:         assert main(["", SAMPLE_HASH]) == 2
       
