    2: class TestVerificationResultEdgeCases:
    1:     def test_equality_same_values(self):
    1:         a = VerificationResult(value=1, label="SOVEREIGN", description="test")
    1:         b = VerificationResult(value=1, label="SOVEREIGN", description="test")
    1:         assert a == b
       
    1:     def test_inequality_different_values(self):
    1:         a = VerificationResult(value=1, label="A", description="test")
    1:         b = VerificationResult(value=0, label="A", description="test")
    1:         assert a != b
       
    1:     def test_hashable(self):
               """Frozen dataclasses should be hashable."""
    1:         s = {SOVEREIGN, NULL}
    1:         assert len(s) == 2
       
    1:     def test_repr_contains_fields(self):
    1:         r = repr(SOVEREIGN)
    1:         assert "SOVEREIGN" in r
    1:         assert "1" in r
       
    1:     def test_to_dict_returns_new_dict_each_call(self):
    1:         d1 = SOVEREIGN.to_dict()
    1:         d2 = SOVEREIGN.to_dict()
    1:         assert d1 == d2
    1:         assert d1 is not d2
       
    1:     def test_negative_value_is_falsy(self):
    1:         negative_value_result = VerificationResult(value=-1, label="X", description="Y")
    1:         assert bool(negative_value_result) is False
       
       
