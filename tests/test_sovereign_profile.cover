    1: def test_build_personal_profile_generates_signed_identity():
    1:     profile = build_personal_profile(name="Lewis", handle="ljbudgie")
       
    1:     assert profile["name"] == "Lewis"
    1:     assert profile["handle"] == "ljbudgie"
    1:     assert profile["preferred_signature_block"] == "Lewis [Burgess Principle]"
    1:     assert len(profile["private_key_hex"]) == 64
    1:     assert len(profile["public_key_hex"]) == 64
    1:     assert len(profile["key_fingerprint"]) == 16
    1:     assert profile["mirror_mode_enabled"] is False
    1:     assert profile["mirror_mode_activated_at"] == ""
    1:     assert verify_personal_profile(profile) is True
       
       
    1: def test_build_personal_profile_rejects_blank_name():
    2:     with pytest.raises(ValueError, match="name must be a non-empty string"):
    1:         build_personal_profile(name="   ")
       
       
    1: def test_save_and_load_personal_profile_round_trip(tmp_path):
    2:     profile = build_personal_profile(
    1:         name="Lewis",
    1:         handle="ljbudgie",
    1:         preferred_signature_block="Lewis / Burgess Principle",
           )
       
    1:     saved = save_personal_profile(profile, "correct horse battery staple", root=tmp_path)
    1:     loaded = load_personal_profile("correct horse battery staple", root=tmp_path)
    1:     summary = load_personal_profile_summary(root=tmp_path)
       
    1:     assert Path(saved["path"]).exists()
    1:     assert loaded["signed_profile"] == profile["signed_profile"]
    1:     assert loaded["profile_signature"] == profile["profile_signature"]
    1:     assert summary == saved["profile"]
    1:     assert summary["name"] == "Lewis"
    1:     assert summary["key_fingerprint"] == profile["key_fingerprint"]
       
       
    1: def test_load_personal_profile_rejects_wrong_passphrase(tmp_path):
    1:     profile = build_personal_profile(name="Lewis")
    1:     save_personal_profile(profile, "correct horse battery staple", root=tmp_path)
       
    2:     with pytest.raises(CryptoError):
    1:         load_personal_profile("wrong passphrase", root=tmp_path)
       
       
    1: def test_verify_personal_profile_rejects_tampered_signature():
    1:     profile = build_personal_profile(name="Lewis")
       
    4:     assert (
    4:         verify_personal_profile({**profile, "profile_signature": "00" * 64}) is False
           )
       
       
    1: def test_helpers_expose_public_summary_defaults_and_storage_path(tmp_path):
    1:     summary = summarize_personal_profile({})
       
    1:     assert summary == {
    1:         "name": "",
    1:         "handle": "ljbudgie",
    1:         "preferred_signature_block": "",
    1:         "key_fingerprint": "",
    1:         "public_key_hex": "",
    1:         "profile_signature": "",
    1:         "signed_at": "",
    1:         "mirror_mode_enabled": False,
    1:         "mirror_mode_activated_at": "",
    1:         "mirror_greeting_style": "neutral_professional",
    1:         "mirror_custom_greeting": "",
    1:         "mirror_reflection_scope": "vault_only",
    1:         "mirror_greeting": "",
           }
    1:     assert profile_signature_block(" Lewis ", "  ") == ""
    1:     assert mirror_mode_prompt("Lewis") == "Lewis — local profile loaded."
    1:     assert mirror_mode_prompt("Lewis", greeting_style="warm_personal") == "Hello Lewis — Mirror Mode is ready on this device."
    1:     assert mirror_mode_prompt("Lewis", greeting_style="minimal") == "Mirror Mode active."
    1:     assert mirror_mode_prompt("Lewis", custom_greeting="Welcome back, Lewis.") == "Welcome back, Lewis."
    1:     assert normalize_mirror_greeting_style("Warm & Personal") == "warm_personal"
    1:     assert normalize_mirror_reflection_scope("all documents") == "all_documents"
    1:     assert fingerprint_public_key("ab" * 32, length=8) == "9a2db2e2"
    1:     assert profile_path(tmp_path) == tmp_path / ".sovereign-vault" / "personal-profile.json"
       
       
    1: def test_save_personal_profile_requires_passphrase(tmp_path):
    1:     profile = build_personal_profile(name="Lewis")
       
    2:     with pytest.raises(ValueError, match="vault_passphrase must be a non-empty string"):
    1:         save_personal_profile(profile, "", root=tmp_path)
       
       
    1: def test_save_personal_profile_rejects_invalid_signature(tmp_path):
    1:     profile = build_personal_profile(name="Lewis")
       
    2:     with pytest.raises(ValueError, match="profile signature verification failed"):
    2:         save_personal_profile(
    1:             {**profile, "profile_signature": "00" * 64},
    1:             "correct horse battery staple",
    1:             root=tmp_path,
               )
       
       
    1: def test_load_personal_profile_requires_passphrase(tmp_path):
    1:     profile = build_personal_profile(name="Lewis")
    1:     save_personal_profile(profile, "correct horse battery staple", root=tmp_path)
       
    2:     with pytest.raises(ValueError, match="vault_passphrase must be a non-empty string"):
    1:         load_personal_profile("", root=tmp_path)
       
       
    1: def test_load_personal_profile_rejects_tampered_signature_after_decryption(tmp_path):
    1:     profile = build_personal_profile(name="Lewis")
    1:     saved = save_personal_profile(profile, "correct horse battery staple", root=tmp_path)
    1:     record = json.loads(Path(saved["path"]).read_text(encoding="utf-8"))
    2:     record["encrypted_payload"] = sovereign_profile._encrypt_payload(  # noqa: SLF001
    1:         {**profile, "profile_signature": "00" * 64},
    1:         "correct horse battery staple",
           )
    1:     Path(saved["path"]).write_text(json.dumps(record), encoding="utf-8")
       
    2:     with pytest.raises(ValueError, match="profile signature verification failed"):
    1:         load_personal_profile("correct horse battery staple", root=tmp_path)
       
       
    1: def test_setup_personal_profile_loads_existing_profile(tmp_path):
    2:     created = setup_personal_profile(
    1:         vault_passphrase="correct horse battery staple",
    1:         root=tmp_path,
    1:         name="Lewis",
           )
    2:     loaded = setup_personal_profile(
    1:         vault_passphrase="correct horse battery staple",
    1:         root=tmp_path,
    1:         name="Ignored on reload",
           )
       
    1:     assert created["created"] is True
    1:     assert loaded["created"] is False
    1:     assert loaded["profile"]["name"] == "Lewis"
       
       
    1: def test_setup_personal_profile_can_enable_mirror_mode_for_existing_profile(tmp_path):
    2:     setup_personal_profile(
    1:         vault_passphrase="correct horse battery staple",
    1:         root=tmp_path,
    1:         name="Lewis",
           )
       
    2:     updated = setup_personal_profile(
    1:         vault_passphrase="correct horse battery staple",
    1:         root=tmp_path,
    1:         mirror_mode_enabled=True,
           )
       
    1:     assert updated["created"] is False
    1:     assert updated["profile"]["mirror_mode_enabled"] is True
    1:     assert updated["profile"]["mirror_greeting"] == "Lewis — local profile loaded."
    1:     loaded = load_personal_profile("correct horse battery staple", root=tmp_path)
    1:     assert loaded["mirror_mode_enabled"] is True
    1:     assert loaded["mirror_mode_activated_at"]
       
       
    1: def test_setup_personal_profile_can_store_mirror_preferences(tmp_path):
    2:     setup_personal_profile(
    1:         vault_passphrase="correct horse battery staple",
    1:         root=tmp_path,
    1:         name="Lewis",
           )
       
    2:     updated = setup_personal_profile(
    1:         vault_passphrase="correct horse battery staple",
    1:         root=tmp_path,
    1:         mirror_mode_enabled=True,
    1:         mirror_greeting_style="warm_personal",
    1:         mirror_custom_greeting="Welcome back, Lewis.",
    1:         mirror_reflection_scope="all_documents",
           )
       
    1:     assert updated["profile"]["mirror_greeting_style"] == "warm_personal"
    1:     assert updated["profile"]["mirror_custom_greeting"] == "Welcome back, Lewis."
    1:     assert updated["profile"]["mirror_reflection_scope"] == "all_documents"
    1:     assert updated["profile"]["mirror_greeting"] == "Welcome back, Lewis."
       
       
    1: def test_setup_personal_profile_requires_name_when_creating_new_profile(tmp_path):
    2:     with pytest.raises(ValueError, match="name must be a non-empty string"):
    2:         setup_personal_profile(
    1:             vault_passphrase="correct horse battery staple",
    1:             root=tmp_path,
