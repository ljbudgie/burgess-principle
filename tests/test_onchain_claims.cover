    2: class TestCanonicalClaimJson:
    1:     def test_returns_valid_json(self):
    1:         result = _canonical_claim_json("details", "2026-01-01T00:00:00Z", "aa" * 32, "bb" * 32)
    1:         data = json.loads(result)
    1:         assert isinstance(data, dict)
       
    1:     def test_contains_expected_keys(self):
    1:         result = _canonical_claim_json("my claim", "ts", "aa" * 32, "bb" * 32)
    1:         data = json.loads(result)
    1:         assert set(data.keys()) == {"claim_details", "nonce", "public_key", "timestamp"}
       
    1:     def test_values_preserved(self):
    1:         result = _canonical_claim_json("hello", "2026-01-01", "cc" * 32, "dd" * 32)
    1:         data = json.loads(result)
    1:         assert data["claim_details"] == "hello"
    1:         assert data["timestamp"] == "2026-01-01"
    1:         assert data["nonce"] == "cc" * 32
    1:         assert data["public_key"] == "dd" * 32
       
    1:     def test_keys_are_sorted(self):
    1:         result = _canonical_claim_json("x", "y", "aa" * 32, "bb" * 32)
    1:         data = json.loads(result)
    1:         keys = list(data.keys())
    1:         assert keys == sorted(keys)
       
    1:     def test_compact_separators(self):
    1:         result = _canonical_claim_json("x", "y", "aa" * 32, "bb" * 32)
               # Compact JSON should not have spaces after : or ,
    1:         assert ": " not in result
    1:         assert ", " not in result
       
    1:     def test_deterministic(self):
    1:         r1 = _canonical_claim_json("a", "b", "cc" * 32, "dd" * 32)
    1:         r2 = _canonical_claim_json("a", "b", "cc" * 32, "dd" * 32)
    1:         assert r1 == r2
       
    1:     def test_different_inputs_produce_different_json(self):
    1:         r1 = _canonical_claim_json("a", "b", "cc" * 32, "dd" * 32)
    1:         r2 = _canonical_claim_json("x", "b", "cc" * 32, "dd" * 32)
    1:         assert r1 != r2
       
       
