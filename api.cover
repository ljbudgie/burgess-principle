    1: """Lightweight FastAPI wrapper for the Burgess Principle Binary Test.
       
       Start the server::
       
           uvicorn api:app --reload
       
       Then POST to ``/verify``::
       
           curl -X POST http://127.0.0.1:8000/verify \
                -H "Content-Type: application/json" \
                -d '{"reasoning_text": "...", "provided_hash": "..."}'
       
       Or POST to ``/claims/verify`` to verify an on-chain claim receipt::
       
           curl -X POST http://127.0.0.1:8000/claims/verify \
                -H "Content-Type: application/json" \
                -d '{"commitment_hash": "...", "signature": "...", "public_key_hex": "..."}'
       
       Requires the ``api`` optional dependency group::
       
           pip install -e ".[api]"
       """
       
    1: from __future__ import annotations
       
    1: import sys
    1: import os
       
    1: from fastapi import FastAPI
    1: from pydantic import BaseModel, Field
       
    1: from verify_scrutiny import verify_instrument
       
    2: app = FastAPI(
    1:     title="Burgess Principle Binary Test",
    1:     description="SOVEREIGN / NULL verification API with optional on-chain claims support.",
    1:     version="1.1.1",
       )
       
       
       # ---------------------------------------------------------------------------
       # Request / response models
       # ---------------------------------------------------------------------------
       
    2: class VerifyRequest(BaseModel):
    1:     """Payload for the /verify endpoint."""
       
    2:     reasoning_text: str = Field(
    1:         ..., min_length=1, description="The reasoning text to verify."
           )
    2:     provided_hash: str = Field(
    1:         ...,
    1:         min_length=64,
    1:         max_length=64,
    1:         pattern=r"^[0-9a-fA-F]{64}$",
    1:         description="The expected SHA-256 hex-digest (Sovereign Hash).",
           )
       
       
    2: class VerifyResponse(BaseModel):
    1:     """Structured result returned by the /verify endpoint."""
       
    1:     status: str
    1:     code: int
    1:     description: str
       
       
    2: class ClaimVerifyRequest(BaseModel):
    1:     """Payload for the /claims/verify endpoint."""
       
    2:     commitment_hash: str = Field(
    1:         ...,
    1:         min_length=64,
    1:         max_length=64,
    1:         pattern=r"^[0-9a-fA-F]{64}$",
    1:         description="The SHA-256 commitment hash (64 hex characters).",
           )
    2:     signature: str = Field(
    1:         ...,
    1:         min_length=128,
    1:         max_length=128,
    1:         pattern=r"^[0-9a-fA-F]{128}$",
    1:         description="The Ed25519 signature (128 hex characters / 64 bytes).",
           )
    2:     public_key_hex: str = Field(
    1:         ...,
    1:         min_length=64,
    1:         max_length=64,
    1:         pattern=r"^[0-9a-fA-F]{64}$",
    1:         description="The claimant's Ed25519 public key (64 hex characters).",
           )
       
       
    2: class ClaimVerifyResponse(BaseModel):
    1:     """Structured result returned by the /claims/verify endpoint."""
       
    1:     valid: bool
    1:     commitment_hash: str
