    1:     assert "The exchange froze my account and blocked withdrawals." in filled
    1:     assert profile["transaction_hash"] in filled
    1:     assert profile["wallet_address"] in filled
    1:     assert "0xcommitment" in filled
    1:     assert "claim-123" in filled
    1:     assert "Alex Example" in filled
    1:     assert "alex@example.com | 07123 456789" in filled
    1:     _assert_all_placeholders_resolved(filled)
       
       
