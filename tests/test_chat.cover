    2: class TestDoOptions:
    1:     def test_returns_200(self):
    1:         h = _make_handler(b"")
    1:         h.do_OPTIONS()
    1:         assert h._response_code == 200
       
    1:     def test_cors_allow_origin(self):
    1:         h = _make_handler(b"")
    1:         h.do_OPTIONS()
    1:         assert h._response_headers.get("Access-Control-Allow-Origin") == "*"
       
    1:     def test_cors_allow_methods(self):
    1:         h = _make_handler(b"")
    1:         h.do_OPTIONS()
    1:         assert "POST" in h._response_headers.get("Access-Control-Allow-Methods", "")
    1:         assert "OPTIONS" in h._response_headers.get("Access-Control-Allow-Methods", "")
       
    1:     def test_cors_allow_headers(self):
    1:         h = _make_handler(b"")
    1:         h.do_OPTIONS()
    1:         assert "Content-Type" in h._response_headers.get("Access-Control-Allow-Headers", "")
       
       
