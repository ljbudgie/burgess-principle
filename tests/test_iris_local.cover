                   "--model", "test.gguf",
                   "--context", "4096",
                   "--port", "9000",
                   "--gpu",
                   "--no-browser",
               ])
    1:         assert args.model == "test.gguf"
    1:         assert args.context == 4096
    1:         assert args.port == 9000
    1:         assert args.gpu is True
    1:         assert args.no_browser is True
       
       
