               ),
           },
    1:     {
    1:         "id": "DEFECT_02",
    1:         "title": "Rubber-Stamping",
               "description": (
    1:             "Reliance on supplier affidavits without independent verification."
               ),
               "axiom": (
    1:             "The court acts as a processing center rather than an independent "
