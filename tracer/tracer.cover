    1: """TRACER — defect schema definitions for the Burgess Principle."""
       
    1: from __future__ import annotations
       
    1: from typing import TypedDict
       
       
    2: class Defect(TypedDict):
    1:     """Schema for a single scrutiny defect."""
       
    1:     id: str
    1:     title: str
    1:     description: str
    1:     axiom: str
       
       
       # Each defect is a dict with an id, title, description, and axiom.
    1: DEFECT_SCHEMA: list[Defect] = [
    1:     {
    1:         "id": "DEFECT_01",
    1:         "title": "Bulk Approval Without Scrutiny",
               "description": (
    1:             "Warrants processed in batches without individual judicial review."
               ),
               "axiom": (
    1:             "Violates 'The Judicial Mind.' If a judge did not scrutinize the "
