    2: class TestDefectAxiomContent:
    1:     def test_defect_01_axiom_mentions_judicial_mind(self):
    1:         defect = get_defect("DEFECT_01")
    1:         assert defect is not None
    1:         assert "judicial mind" in defect["axiom"].lower()
       
    1:     def test_defect_02_axiom_mentions_processing_center(self):
    1:         defect = get_defect("DEFECT_02")
    1:         assert defect is not None
    1:         assert "processing center" in defect["axiom"].lower()
       
    1:     def test_defect_03_axiom_mentions_fraud(self):
    1:         defect = get_defect("DEFECT_03")
    1:         assert defect is not None
    1:         assert "fraud" in defect["axiom"].lower()
       
    1:     def test_defect_04_axiom_mentions_corrupted(self):
    1:         defect = get_defect("DEFECT_04")
    1:         assert defect is not None
    1:         assert "corrupted" in defect["axiom"].lower()
       
    1:     def test_all_defects_have_substantive_axioms(self):
               # Axioms should be meaningful sentences, not just a few words
    1:         min_axiom_length = 10
    5:         for defect in DEFECT_SCHEMA:
    4:             assert len(defect["axiom"].strip()) > min_axiom_length, (
                       f"{defect['id']} axiom is too short"
                   )
