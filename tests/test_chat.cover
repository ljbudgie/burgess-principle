    2: class TestDoPostSuccess:
    1:     def _make_mock_stream(self, chunks):
               """Create a mock streaming response from OpenAI."""
    2:         mock_chunks = []
    5:         for text in chunks:
    3:             chunk = MagicMock()
    3:             choice = MagicMock()
    3:             choice.delta.content = text
    3:             chunk.choices = [choice]
    3:             mock_chunks.append(chunk)
    2:         return mock_chunks
       
    1:     def test_successful_stream(self):
    3:         body = json.dumps({
    1:             "messages": [{"role": "user", "content": "Hello"}]
    1:         }).encode()
    1:         h = _make_handler(body)
    1:         h.headers = {"Content-Length": str(len(body))}
       
    1:         mock_stream = self._make_mock_stream(["Hello", " world"])
    1:         mock_client = MagicMock()
    1:         mock_client.chat.completions.create.return_value = mock_stream
       
    2:         with patch.dict(os.environ, {"IRIS_API_KEY": "test-key"}):
    2:             with patch.object(_chat_mod, "_get_client", return_value=mock_client):
    1:                 h.do_POST()
       
    1:         assert h._response_code == 200
    1:         assert h._response_headers.get("Content-Type") == "text/event-stream"
       
    1:         output = h.wfile.getvalue().decode()
    1:         assert "Hello" in output
    1:         assert "world" in output
    1:         assert "data: [DONE]" in output
       
    1:     def test_stream_with_empty_delta(self):
               """Chunks with no content should be skipped."""
    3:         body = json.dumps({
    1:             "messages": [{"role": "user", "content": "test"}]
    1:         }).encode()
    1:         h = _make_handler(body)
    1:         h.headers = {"Content-Length": str(len(body))}
       
    1:         empty_chunk = MagicMock()
    1:         empty_choice = MagicMock()
    1:         empty_choice.delta.content = None
    1:         empty_chunk.choices = [empty_choice]
       
    1:         content_chunk = MagicMock()
    1:         content_choice = MagicMock()
    1:         content_choice.delta.content = "response"
    1:         content_chunk.choices = [content_choice]
       
    1:         mock_client = MagicMock()
    1:         mock_client.chat.completions.create.return_value = [empty_chunk, content_chunk]
       
    2:         with patch.dict(os.environ, {"IRIS_API_KEY": "test-key"}):
    2:             with patch.object(_chat_mod, "_get_client", return_value=mock_client):
    1:                 h.do_POST()
       
    1:         assert h._response_code == 200
    1:         output = h.wfile.getvalue().decode()
    1:         assert "response" in output
    1:         assert "data: [DONE]" in output
       
