    1:     def test_invalid_hash_exits_two(self):
    1:         assert main([SAMPLE_TEXT, "not-a-hash"]) == 2
       
    1:     def test_error_triggers_logging(self, caplog):
    1:         import logging
    2:         with caplog.at_level(logging.ERROR, logger="verify_scrutiny"):
    1:             main(["", SAMPLE_HASH])
