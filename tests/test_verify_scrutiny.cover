       # ---------------------------------------------------------------------------
       # CLI — edge cases
       # ---------------------------------------------------------------------------
       
    2: class TestCLIEdgeCases:
    1:     def test_main_with_none_argv_triggers_argparse(self):
               """main(None) delegates to sys.argv; argparse errors out."""
    1:         import sys
    1:         original = sys.argv
    1:         try:
    1:             sys.argv = ["verify_scrutiny"]
    2:             with pytest.raises(SystemExit) as exc_info:
    1:                 main(None)
    1:             assert exc_info.value.code == 2  # argparse exits with code 2
               finally:
    1:             sys.argv = original
       
    1:     def test_invalid_hash_error_message_goes_to_stderr(self, capsys):
    1:         main([SAMPLE_TEXT, "not-a-hash"])
    1:         captured = capsys.readouterr()
    1:         assert "Error:" in captured.err
    1:         assert "64-character hexadecimal" in captured.err
       
    1:     def test_type_error_from_cli_impossible_via_argparse(self):
               """argparse always passes strings, so TypeError path is not hit via CLI."""
               # Verifying that both args as strings never raise TypeError
    1:         result = main(["any-text", "a" * 64])
    1:         assert result in (0, 1)
       
    1:     def test_module_main_guard_invokes_main(self, monkeypatch):
    1:         script_path = Path(__file__).resolve().parents[1] / "verify_scrutiny.py"
    2:         monkeypatch.setattr(
    1:             "sys.argv",
    1:             ["verify_scrutiny.py", SAMPLE_TEXT, SAMPLE_HASH],
               )
       
    2:         with pytest.raises(SystemExit) as exc_info:
    1:             runpy.run_path(str(script_path), run_name="__main__")
       
    1:         assert exc_info.value.code == 0
       
       
