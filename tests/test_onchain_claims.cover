    1:             claim_details="Roundtrip test",
    1:             target_entity="Org",
    1:             category="enforcement",
    1:             private_key_hex=PRIVATE_KEY,
               )
    2:         result = verify_onchain_receipt(
    1:             commitment_hash=claim.commitment_hash,
    1:             signature=claim.signature,
    1:             public_key_hex=claim.public_key,
               )
    1:         assert result.valid is True
    1:         assert "verified" in result.details.lower()
       
    1:     def test_wrong_signature_returns_false(self):
    2:         claim = generate_onchain_claim(
    1:             claim_details="Test",
    1:             target_entity="Org",
    1:             category="enforcement",
    1:             private_key_hex=PRIVATE_KEY,
               )
    1:         bad_sig = "aa" * 64
    2:         result = verify_onchain_receipt(
    1:             commitment_hash=claim.commitment_hash,
    1:             signature=bad_sig,
    1:             public_key_hex=claim.public_key,
               )
    1:         assert result.valid is False
    1:         assert "failed" in result.details.lower()
       
    1:     def test_wrong_public_key_returns_false(self):
    2:         claim = generate_onchain_claim(
    1:             claim_details="Test",
    1:             target_entity="Org",
    1:             category="enforcement",
    1:             private_key_hex=PRIVATE_KEY,
               )
    1:         other_priv, other_pub = _make_keypair()
    2:         result = verify_onchain_receipt(
    1:             commitment_hash=claim.commitment_hash,
    1:             signature=claim.signature,
    1:             public_key_hex=other_pub,
               )
    1:         assert result.valid is False
       
    1:     def test_tampered_hash_returns_false(self):
    2:         claim = generate_onchain_claim(
    1:             claim_details="Test",
